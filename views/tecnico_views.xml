<?xml version='1.0' encoding='UTF-8'?>
<odoo>

<!-- record = un registro en la tabla ir.ui.view -->
<record id='helpdesk_tecnico_view_list' model='ir.ui.view'>
    <field name='name'>helpdesk.tecnico.list</field>
    <field name='model'>helpdesk.tecnico</field>
    <field name='arch' type='xml'>
        <tree>
            <field name='name'/>
            <field name='email'/>
            <field name='nivel_soporte'/>
            <field name='especialidad'/>
            <field name='activo'/>
        </tree>
    </field>
</record>

<record id='helpdesk_tecnico_view_form' model='ir.ui.view'>
    <field name='name'>helpdesk.tecnico.form</field>
    <field name='model'>helpdesk.tecnico</field>
    <field name='arch' type='xml'>
        <form>
            <sheet>
<group>
    <field name='name'/>
    <field name='email'/>
    <field name='nivel_soporte'/>
    <field name='especialidad'/>
    <field name='activo'/>
    <field name='user_id'/>
</group>
            </sheet>
        </form>
    </field>
</record>

<record id='helpdesk_tecnico_action' model='ir.actions.act_window'>
    <field name='name'>Tecnicos</field>
    <field name='res_model'>helpdesk.tecnico</field>
    <field name='view_mode'>tree,form</field>
</record>

<menuitem id='helpdesk_menu_tecnico'
          name='Tecnicos'
          parent='helpdesk_menu_config'
          action='helpdesk_tecnico_action'
          sequence='30'/>

</odoo>

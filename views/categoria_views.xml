<?xml version='1.0' encoding='UTF-8'?>
<odoo>

    <!-- VISTA LISTA -->
    <record id='helpdesk_categoria_view_tree' model='ir.ui.view'>
        <field name='name'>helpdesk.categoria.tree</field>
        <field name='model'>helpdesk.categoria</field>
        <field name='arch' type='xml'>
            <tree>
                <field name='name'/>
                <field name='descripcion'/>
            </tree>
        </field>
    </record>

    <!-- VISTA FORMULARIO -->
    <record id='helpdesk_categoria_view_form' model='ir.ui.view'>
        <field name='name'>helpdesk.categoria.form</field>
        <field name='model'>helpdesk.categoria</field>
        <field name='arch' type='xml'>
            <form>
                <sheet>
                    <group>
                        <field name='name'/>
                        <field name='descripcion'/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACCION -->
    <record id='helpdesk_categoria_action' model='ir.actions.act_window'>
        <field name='name'>Categorías</field>
        <field name='res_model'>helpdesk.categoria</field>
        <field name='view_mode'>tree,form</field>
    </record>

    <!-- MENUS -->
    <menuitem id='helpdesk_menu_root'
              name='Helpdesk'
              sequence='10'/>

    <menuitem id='helpdesk_menu_config'
              name='Configuración'
              parent='helpdesk_menu_root'
              sequence='90'/>

    <menuitem id='helpdesk_menu_categoria'
              name='Categorías'
              parent='helpdesk_menu_config'
              action='helpdesk_categoria_action'
              sequence='10'/>

</odoo>